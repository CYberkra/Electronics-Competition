#----------------------以太网---------------------------
create_clock -period 8.000 -name eth_rxc [get_ports eth_rxc]

set_property -dict {PACKAGE_PIN AD26 IOSTANDARD LVCMOS33} [get_ports eth_rst_n]
set_property -dict {PACKAGE_PIN AB27 IOSTANDARD LVCMOS33} [get_ports eth_rxc]
