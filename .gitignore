# Vivado generated files
*.cache/
*.hw/
*.ip_user_files/
*.runs/
*.sim/
*.gen/
.Xil/
*.jou
*.log
*.pb
*.wdb
*.vds
*.rpt
*.dcp

# Vivado IP generated outputs (keep .xci only)
vivado/**/ip/*/*/
!vivado/**/ip/*/*.xci

# Vivado wave config
vivado/*.wcfg

# Simulation outputs
sim/work/xsim.dir/
sim/work/*.vcd

# Build logs
build_*.log
rebuild_*.log

# Python cache
__pycache__/
*.pyc

# OS files
.DS_Store
Thumbs.db

# Bitstream / binary outputs (can be regenerated)
*.bit
*.bin
*.ltx
